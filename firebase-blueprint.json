{
  "entities": {
    "ProductionEntry": {
      "title": "Production Entry",
      "description": "Represents a single production record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "machine": { "type": "string" },
        "shift": { "type": "string" },
        "operator": { "type": "string" },
        "product": { "type": "string" },
        "netWeight": { "type": "number" },
        "borraWeight": { "type": "number" },
        "ecoAWeight": { "type": "number" },
        "ecoBProdWeight": { "type": "number" },
        "ecoBMaintWeight": { "type": "number" },
        "stopMaint": { "type": "number" },
        "stopProcess": { "type": "number" },
        "stopOther": { "type": "number" },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "machine", "shift", "operator", "product", "netWeight", "userId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registration": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "shift": { "type": "string" },
        "machine": { "type": "string" },
        "sector": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "PersonnelLog": {
      "title": "Personnel Log",
      "description": "Logs changes in personnel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "employeeName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "user": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "SystemUser": {
      "title": "System User",
      "description": "User with access to the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "registration": { "type": "string" },
        "role": { "type": "string" },
        "password": { "type": "string" },
        "isFirstAccess": { "type": "boolean" },
        "permissions": { "type": "object" }
      }
    },
    "Settings": {
      "title": "Global Settings",
      "description": "Configuration for the system.",
      "type": "object",
      "properties": {
      "properties": {
        "operators": { "type": "array" },
        "availableRoles": { "type": "array" },
        "goals": { "type": "object" },
        "systemName": { "type": "string" },
        "loginSystemName": { "type": "string" },
        "loginSystemSubtitle": { "type": "string" },
        "systemLogo": { "type": "string" }
      }
    },
    "Collaborator": {
      "title": "Collaborator",
      "description": "Represents a collaborator in the central database.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registration": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "birthDate": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "TrainingRecord": {
      "title": "Training Record",
      "description": "Represents a completed training form.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "training": { "type": "string" },
        "date": { "type": "string" },
        "duration": { "type": "string" },
        "location": { "type": "string" },
        "instructor": { "type": "string" },
        "content": { "type": "string" },
        "participants": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    },
    "FcmToken": {
      "title": "FCM Token",
      "description": "Token for push notifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "token": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "productionEntries": { "schema": "ProductionEntry", "description": "Production records" },
    "employees": { "schema": "Employee", "description": "Employee records" },
    "personnelLogs": { "schema": "PersonnelLog", "description": "Personnel change logs" },
    "system_users": { "schema": "SystemUser", "description": "System access users" },
    "settings": { "schema": "Settings", "description": "Global settings" },
    "shifts": { "schema": "object", "description": "Available shifts" },
    "collaborators": { "schema": "Collaborator", "description": "Central database of collaborators" },
    "training_records": { "schema": "TrainingRecord", "description": "Saved training forms" },
    "training_template": { "schema": "TrainingTemplate", "description": "Layout configuration for training PDF" },
    "fcm_tokens": { "schema": "FcmToken", "description": "Push notification tokens" }
  }
}
